# Server Config
# PORT: Port to run the proxy server on (default: 8082)
PORT=8082

# Proxy API Key (optional - protects your proxy from unauthorized access)
# If blank or "<replaceme>", a random session key is auto-generated on startup
# (format: 16chars.16chars, e.g., "aBcD1234eFgH5678.XyZ90123aBcD4567")
PROXY_API_KEY="<replaceme>"


# NVIDIA NIM Config
# Get your API key at https://build.nvidia.com/settings/api-keys
NVIDIA_NIM_API_KEY="<replaceme>"
NIM_MAX_TOKENS=202000


# Model Configuration
# Format: owner/model-name (without provider prefix)
# Examples: "meta/llama3-70b-instruct", "qwen/qwen3.5-397b-a17b"
MODEL="z-ai/glm5"


# Provider Config (Rate Limiting)
# PROVIDER_RATE_LIMIT: Maximum requests per time window (default: 40 for NVIDIA NIM)
# PROVIDER_RATE_WINDOW: Time window in seconds (default: 60 for 1 minute)
# PROVIDER_MAX_CONCURRENCY: Maximum simultaneous API streams (default: 5)
# Example: 40 requests per 60 seconds = 40 req/min (NVIDIA NIM free tier)
# Adjust if you have a higher tier
PROVIDER_RATE_LIMIT=40
PROVIDER_RATE_WINDOW=60
PROVIDER_MAX_CONCURRENCY=5


# HTTP client timeouts (seconds) for provider API requests
HTTP_READ_TIMEOUT=300
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=2


# Optimization Settings (all default to true)
# These speed up Claude Code by mocking/skipping unnecessary requests
FAST_PREFIX_DETECTION=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true


# ============================================================================
# Discord Bot Configuration (Optional)
# ============================================================================
# Get bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=""

# Guild (server) IDs the bot is locked to (comma-separated for multiple servers)
DISCORD_GUILD_ID=0
# Example with multiple servers: DISCORD_GUILD_ID=123456789,987654321

# Channel IDs for control panel (comma-separated for multiple channels)
DISCORD_CONTROL_CHANNEL_ID=0
# Example with multiple control channels: DISCORD_CONTROL_CHANNEL_ID=123456789,987654321

# Category IDs where conversation channels are created (comma-separated)
DISCORD_CONVERSATION_CATEGORY_ID=0
# Example with multiple categories: DISCORD_CONVERSATION_CATEGORY_ID=123456789,987654321

# Owner configuration (your Discord user ID)
DISCORD_OWNER_ID=0

# If true, only owner can use the bot; if false, anyone in the server can use it
DISCORD_OWNER_ONLY=true

# Token Management for Conversation Compaction
DISCORD_MAX_TOKENS=202000
DISCORD_COMPACT_THRESHOLD=0.8

# Rate Limiting (per-channel cooldown)
DISCORD_USER_COOLDOWN=10
DISCORD_SERVER_LIMIT=20
DISCORD_SERVER_WINDOW=60

# System Prompt - Customizes bot personality
DISCORD_SYSTEM_PROMPT="You are a helpful Discord bot. Be friendly, casual, and conversational. Talk like a normal person - don't use formal analysis headers, bullet points, or structured formatting unless specifically asked. Keep responses natural and direct."

# Skip Files - Ignore messages with attachments (future feature to process files)
DISCORD_SKIP_FILES=true

# Message Split Threshold - Split messages at this character count (Discord limit: 2000)
DISCORD_SPLIT_THRESHOLD=1900
